{
  "name": "nextjs-postgresql-template",
  "version": "1.0.0",
  "description": "NETIFLOW Cash Flow System",
  "author": "Feneto",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "seed": "npx tsx src/db/seed.ts",
    "dev:electron": "concurrently \"next dev\" \"wait-on tcp:3000 && electron .\"",
    "build:electron": "next build && node -e \"const fs = require('fs'); fs.cpSync('.next/static', '.next/standalone/.next/static', {recursive: true}); if(fs.existsSync('public')) fs.cpSync('public', '.next/standalone/public', {recursive: true});\" && electron-builder"
  },
  "build": {
    "appId": "com.cashflow.app",
    "productName": "NETIFLOW",
    "icon": "public/img/login.ico",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      ".next/standalone/**/*",
      "main.js",
      "src/db/setup.js",
      ".env.local"
    ],
    "extraMetadata": {
      "main": "main.js"
    }
  },
  "dependencies": {
    "dotenv": "17.3.1",
    "pg": "8.20.0"
  },
  "devDependencies": {
    "drizzle-orm": "0.45.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^1.23.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "@tailwindcss/postcss": "4.1.17",
    "@types/node": "22.19.15",
    "@types/pg": "8.18.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "concurrently": "^10.0.3",
    "drizzle-kit": "0.31.10",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-is-dev": "^3.0.1",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "postcss": "8.5.8",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "wait-on": "^9.0.10"
  }
}
